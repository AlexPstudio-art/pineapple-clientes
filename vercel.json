
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/clientes/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
